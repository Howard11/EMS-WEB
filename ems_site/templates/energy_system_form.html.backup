    <script>
        function toggleAirSystem() {
            const isChecked = document.getElementById("noAirSystem").checked;
            const airSection = document.getElementById("airSection");
            const iceSection = document.getElementById("iceSection");

            const airInputs = document.querySelectorAll("#airTable input, #airTable button");
            const iceInputs = document.querySelectorAll("#iceTable input, #iceTable button");

            // ✅ 禁用/啟用所有輸入元件
            airInputs.forEach(el => el.disabled = isChecked);
            iceInputs.forEach(el => el.disabled = isChecked);

            // ✅ 整個區塊變灰透明
            if (isChecked) {
                airSection.classList.add("disabled-section");
                iceSection.classList.add("disabled-section");
            } else {
                airSection.classList.remove("disabled-section");
                iceSection.classList.remove("disabled-section");
            }
        }

        function toggleAirCompressor() {
            const isChecked = document.getElementById("noAirCompressor").checked;
            const airCompressorSection = document.getElementById("airCompressorSection");

            const compressorInputs = document.querySelectorAll("#airCompressorTable input, #airCompressorTable button");

            // ✅ 禁用/啟用所有輸入元件
            compressorInputs.forEach(el => el.disabled = isChecked);

            // ✅ 整個區塊變灰透明
            if (isChecked) {
                airCompressorSection.classList.add("disabled-section");
            } else {
                airCompressorSection.classList.remove("disabled-section");
            }
        }

        function addRow(tableId, btn) {
            const tbody = document.getElementById(tableId).querySelector("tbody");
            const currentRow = btn.closest("tr");

            // 將當前列的 "+" 改為 "-"
            btn.textContent = "-";
            btn.classList.remove("btn-success");
            btn.classList.add("btn-danger");
            btn.setAttribute("onclick", "removeRow('" + tableId + "', this)");

            // 複製新列
            const newRow = currentRow.cloneNode(true);
            newRow.querySelectorAll("input").forEach(input => input.value = "");

            // 新列的按鈕設為 "+"
            const newBtn = newRow.querySelector("button");
            newBtn.textContent = "+";
            <tr>
                <td><strong>運作天數(日/年)</strong></td>
                <td><input type="number" name="compressor_days_1[]" class="form-control"></td>
                <td><input type="number" name="compressor_days_2[]" class="form-control"></td>
                <td><input type="number" name="compressor_days_3[]" class="form-control"></td>
                <td><input type="number" name="compressor_days_4[]" class="form-control"></td>
                <td><input type="number" name="compressor_days_5[]" class="form-control"></td>
            </tr>
                    </tbody >
                </table >
            </div >

                <div class="text-center">
